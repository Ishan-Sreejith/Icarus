say: "=== Map & Assignment Test ==="
var m: {"a": 1, "b": 2}
say: m
say: "=== List & Indexing Test ==="
var list: [10, 20, 30]
say: list
say: "=== Arithmetic Operations ==="
var x: 5
var y: 3
say: x + y
say: x - y
say: x * y
say: "=== Boolean & Logic ==="
var a: 10
var b: 20
if a < b {
    say: "10 < 20 is true"
}
if b > a {
    say: "20 > 10 is true"
}
